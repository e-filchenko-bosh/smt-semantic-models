@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.2.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.2.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.2.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.2.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.admin-shell.idta.batterypass.material_composition:1.0.1#> .


:HazardousSubstanceClassEnum a samm-c:Enumeration ;
   samm:dataType xsd:string ;
   samm-c:values ( 
      :AcuteToxicity 
	  :SkinCorrosionOrIrritation
	  :EyeDamageOrIrritation
	  ) .

:AcuteToxicity a samm:Value ;
   samm:value "AcuteToxicity" ;
   samm:preferredName "acute toxicity"@en .

:SkinCorrosionOrIrritation a samm:Value ;
   samm:value "SkinCorrosionOrIrritation" ;
   samm:preferredName "skin corrosion or irritation"@en .
   
:EyeDamageOrIrritation a samm:Value ;
   samm:value "EyeDamageOrIrritation" ;
   samm:preferredName "eye damage or irritation"@en .